{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile C++17",
      "type": "shell",
      "command": "g++",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "-std=c++17",
        "${file}",
        "-o",
        "${fileDirname}/output/${fileBasenameNoExtension}.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
